# Copy values into Streamlit Community Cloud: App settings → Secrets.
# Optional: public HTTPS URL to a .zip containing models/saved/*.pkl at zip root.
# Create locally: cd models/saved && zip -r ../../models_bundle.zip *.pkl
# Upload zip to a GitHub Release or any static host, then paste the raw URL here.
#
# MODEL_BUNDLE_URL = "https://github.com/YOUR_USER/YOUR_REPO/releases/download/v1/models_bundle.zip"
